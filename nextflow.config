manifest {
  homePage = 'https://gitlab.epfl.ch/abadreddine/conterminator'
  description = 'Conterminator: a pipeline for terminating contamination'
  mainScript = 'main.nf'
  version = 'v1.2'
  author = 'Alaa Badreddine'
}

// ========================================
// Global Parameters
// ========================================
params {
  max_parallel_samples     = 10  // Maximum number of samples to process in parallel
  outdir                   = null
  hpc_bind_mounts          = null  // Optional bind mounts for HPC (e.g., '--bind /path1 --bind /path2')
  user_home_dir        = "${System.getProperty('user.home')}"  // home directory of user
}


profiles {
  local {
    process.executor = 'local'
  }

  slurm {
    process.executor = 'slurm'

  }

  // Singularity profile for local server
  singularity {
    singularity.enabled = true
    singularity.autoMounts = true
    singularity.runOptions = "--bind /mnt/sas:/mnt/sas --bind ${params.user_home_dir}/rcp_storage:${params.user_home_dir}/rcp_storage"
    process.container = params.singularity_path
  }

  // Singularity profile for HPC cluster (minimal bind mounts)
  singularity_hpc {
    singularity.enabled = true
    singularity.autoMounts = false  // Disable to avoid GVFS/network mount issues
    // Explicitly bind only necessary paths
    singularity.runOptions = "--bind /scratch"
    process.container = params.singularity_path
  }
}

// ========================================
// Per-Process Resource Configuration
// ========================================
process {

  // Default resources for all processes
  cpus = 2
  memory = '4 GB'
  time = '167h'

  // Error handling and parallelization
  maxForks = params.max_parallel_samples
  maxRetries = 2
  errorStrategy = { task.exitStatus in [137,140] ? 'retry' : 'finish' }

  // =====================================
  // High CPU and memory processes
  // =====================================

  withName: 'BUILD_STAR_INDEX' {
    cpus = 20
    memory = { 20.GB * task.attempt }
    time = '167h'
    cache = 'lenient'
  }

  withName: 'STAR_ALIGN' {
    cpus = 20
    time = '167h'
    memory = { 36.GB * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // BLAST processes (parallel execution)
  // =====================================

  withName: 'BLAST_MAPPED_READS_MULTI' {
    cpus = 40
    time = '167h'
    maxForks = 10
    memory = { 40.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'BLAST_UNMAPPED_READS_MULTI' {
    cpus = 40
    time = '167h'
    maxForks = 10
    memory = { 40.GB * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // DecontaMiner processes
  // =====================================

  withName: 'DECONTAMINER_STEP1_STAR_MAPPED' {
    cpus = 20
    time = '167h'
    memory = { 20.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'DECONTAMINER_STEP1_STAR_UNMAPPED' {
    cpus = 20
    time = '167h'
    memory = { 20.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'DECONTAMINER_STEP2' {
    cpus = 20
    time = '167h'
    memory = { 20.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'DECONTAMINER_STEP3' {
    cpus = 4
    time = '167h'
    memory = { 8.GB * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // QC tools (medium resources)
  // =====================================

  withName: 'QUALIMAP_BAMQC' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'QUALIMAP_RNASEQ' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'DEEPTOOLS_GC' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'PICARD_GC_BIAS' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'BEDTOOLS_GC_COVERAGE' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'MAPINSIGHTS' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // FastQ processing
  // =====================================

  withName: 'FASTQ_SCREEN' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'FASTQC_INPUT_FASTQ' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'FASTQC_MAPPED_BAM' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'FASTQC_UNMAPPED_FASTQ' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // Subsetting processes (light)
  // =====================================

  withName: 'SUBSET_FASTQ_FOR_QC' {
    cpus = 1
    time = '167h'
    memory = { 6.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'SUBSET_FASTQ_FOR_STAR' {
    cpus = 1
    time = '167h'
    memory = { 6.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'SUBSET_BAM_FOR_QC' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'SUBSET_UNMAPPED_FOR_BLAST' {
    cpus = 1
    time = '167h'
    memory = { 6.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'SUBSET_UNMAPPED_FOR_DECONTAMINER' {
    cpus = 1
    time = '167h'
    memory = { 8.GB * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // Indexing processes
  // =====================================

  withName: 'INDEX_INPUT_BAM' {
    cpus = 15
    time = '167h'
    memory = { 8.GB * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // Reference preparation
  // =====================================

  withName: 'PREPARE_STRAIN_REFERENCE' {
    cpus = 1
    time = '167h'
    memory = { 4.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'PREP_STRAIN_REFERENCE_FOR_QC' {
    cpus = 15
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // Reporting processes (light)
  // =====================================

  withName: 'BLAST_PLOT_CHARTS' {
    cpus = 2
    time = '167h'
    memory = { 4.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'CONTAMINATION_FINAL_REPORT_MULTI' {
    cpus = 1
    time = '167h'
    memory = { 4.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'MULTIQC' {
    cpus = 4
    time = '167h'
    memory = { 16.GB * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // Utility processes (minimal)
  // =====================================

  withName: 'WRITE_PIPELINE_INFO' {
    cpus = 1
    time = '167h'
    memory = { 2.GB * task.attempt }
    cache = 'lenient'
  }

  withName: 'COPY_SAMPLE_SHEET' {
    cpus = 1
    time = '167h'
    memory = { 1.GB * task.attempt }
    cache = 'lenient'
  }
}


if (params.outdir != null) {
  toReports = params.outdir + "/NextflowReports"

  timeline {
    enabled = true
    overwrite = true
    file = "${toReports}/timeline.html"
  }
  report {
    enabled = true
    overwrite = true
    file = "${toReports}/report.html"
  }
  trace {
    enabled = true
    overwrite = true
    file = "${toReports}/trace.txt"
  }
  dag {
    enabled = true
    overwrite = true
    file = "${toReports}/dag.html"
  }
}
