// ====================
// Pipeline Parameters
// ====================
params {
	// help
	help = false

	// Inputs
	sample_sheet             = null
	outdir                   = "results"
	fastq_pattern            = null

	// FLEXIBLE FASTQ SUBSETTING
	subset_for_fastq_qc      = true      // Subset for FastQ Screen
	subset_fastq_qc_reads    = 100000    // Size for FastQ QC (100k reads)
	subset_for_star          = false     // Use full FASTQ for STAR alignment
	subset_star_reads        = 100000    // Size for STAR if subsampling (100k reads)
	subset_seed              = 100       // Random seed for reproducibility

	// STAR alignment
	run_star_alignment       = true
	star_threads             = 20
	strain                   = null
	strains_base_dir         = "/home/abadreddine/rcp_storage/common/Users/vonalven/HDP_pseudogenomes_construction/Data/HPC_results/HDP_pseudogenomes"
	star_index_dir           = "/mnt/sas/Data/References/Mus"
	star_index_threads       = 20
	star_index_mem           = "32 GB"

	// BAM SUBSETTING FOR QC TOOLS
	subset_bam_for_qc                 = true      // Subset BAMs for QC tools
	bam_qc_subset_mapped              = 200000   // Mapped reads for QC (200k reads)

	// READS SUBSETTING
	subset_unmapped_for_blast         = true   // Subset for BLAST
	subset_mapped_for_blast           = true   // Subset for BLAST
	blast_max_parallel                = 10     // Run up to 10 BLAST jobs in parallel
	subset_unmapped_for_decontaminer  = true   // Subset for DecontaMiner
	subset_mapped_for_decontaminer    = true   // Subset for DecontaMiner
	unmapped_subset_reads             = 100000 // Unmapped reads to keep (100k reads)
	mapped_subset_reads               = 100000 // Unmapped reads to keep (100k reads)

	// Tool toggles
	run_deeptools           = true
	run_picard_gc           = true
	run_fastq_screen        = true
	run_bedtools_gc         = true
	run_decontaminer        = true
	run_mapinsights         = true
	run_contamination_check = true
	run_fastqc              = true

	// Deeptools settings
	blacklist_bed      = null

	// BEDTools windowing
	windowsize         = 500
	window_step        = 250

	// DecontaMiner settings
	decontaminer_dir             = "/mnt/sas/Tools/decontaminer-RNAseq/decontaMiner_1.4"
	decontaminer_config          = "/mnt/sas/Tools/decontaminer-RNAseq/decontaMiner_1.4/config_files/configure.txt"
	decontaminer_pairing         = "P"
	decontaminer_organisms       = "bfv"
	decontaminer_format          = "bam"
	decontaminer_quality_filter  = "yes"
	decontaminer_ribo_filter     = "yes"
	decontaminer_gap             = 5
	decontaminer_mismatch        = 10
	decontaminer_match_len       = 50
	decontaminer_match_threshold = 5
	decontaminer_generate_plots  = true

	// Contamination check
	contamination_gc_min    = 0.60
	contamination_gc_max    = 1.0
	contamination_mapq      = 10
	contamination_blast_dbs = "/mnt/sas/Tools/blast_databases/"
	contamination_evalue    = "1e-10"

	// Mapinsights
	mapinsights_opts   = ""

	// Tool paths
	bedtools_bin       = "/mnt/sas/Tools/bedtools2/bin/bedtools"
	mapinsights_bin    = "/mnt/sas/Tools/mapinsights/mapinsights"
	picard_jar         = "/mnt/sas/Tools/Picard/picard.jar"
	samtools_bin       = "/mnt/sas/Tools/samtools-1.22.1/samtools"
	blastn_bin         = "/mnt/sas/Tools/ncbi-blast-2.17.0+/bin/blastn"
	deeptools_gcbias   = "/mnt/sas/Tools/deepTools/deeptools/computeGCBias.py"
	facount_bin        = "/mnt/sas/Tools/faCount/faCount"
	fa2bit_bin         = "/mnt/sas/Tools/faToTwoBit/faToTwoBit"
	fastq_screen       = "/mnt/sas/Tools/FastQ-Screen-0.16.0/fastq_screen"
	qualimap_bin       = "/mnt/sas/Tools/qualimap_v2.3/qualimap"
	seqtk_bin          = "/mnt/sas/Tools/seqtk/seqtk"
	star_bin           = "/mnt/sas/Tools/STAR_2.7.11b/Linux_x86_64_static/STAR"
	fastqc_bin         = "/mnt/sas/Tools/FastQC/fastqc"
	reformat_bin       = "/mnt/sas/Tools/bbmap/reformat.sh"

	// Qualimap settings
	run_qualimap       = true
	qualimap_mode      = "both"
	qualimap_genome    = "mm10"
	qualimap_java_mem  = "10G"
	qualimap_threads   = 8
	qualimap_skip_dup  = false
	qualimap_protocol  = "strand-specific-reverse"

	// Resources
	max_cpus               = 16
	max_mem                = "32 GB"
	max_time               = "24h"
	max_parallel_samples   = 4

	// FastQ Screen conf
	fastq_screen_conf   = "/mnt/sas/Tools/FastQ-Screen-0.16.0/FastQ_Screen_Genomes/fastq_screen.conf"
	fastq_screen_threads = 8

	// Plotting and reporting
	gc_plot_script         =  "${projectDir}/bin/R/plot_gc_content.R"
	run_blast_plots        = true
	blast_plot             = "${projectDir}/bin/py/plot_blast_pie.py"
	blast_plot_interac     = "${projectDir}/bin/py/interactive_plot_blast_pie.py"
	run_multiqc            = true
	multiqc_bin            = "multiqc"
	multiqc_config         = null
}

manifest {
  homePage = 'https://gitlab.epfl.ch/abadreddine/conterminator'
  description = 'Conterminator: a pipeline for terminating contamination'
  mainScript = 'main.nf'
  version = 'v1.0'
  author = 'Alaa Badreddine'
}


profiles {
  local {
    process.executor = 'local'
  }
  cluster {
    process.executor = 'slurm'
  }
  singularity {
    singularity.enabled = false
    singularity.libraryDir = "/path/to/shared/folder/image.sif"
    // singularity.runOptions = ""    // Specify extra command line options supported by singularity exec
  }
}
