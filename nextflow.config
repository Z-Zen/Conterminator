manifest {
  homePage = 'https://gitlab.epfl.ch/abadreddine/conterminator'
  description = 'Conterminator: a pipeline for terminating contamination'
  mainScript = 'main.nf'
  version = 'v1.2'
  author = 'Alaa Badreddine'
}

// ========================================
// Global Parameters
// ========================================
params {
  max_parallel_samples     = 10  // Maximum number of samples to process in parallel (local default)
  outdir                   = null
  hpc_bind_mounts          = null
  user_home_dir            = "${System.getProperty('user.home')}"
  
  // Resource multiplier (cpus and memory multiplier)
  resource_multiplier      = 1
  // Parallel samples multiplier (parallel jobs multiplier)
  parallel_multiplier      = 1
}

profiles {
  local {
    process.executor = 'local'
  }

  slurm {
    process.executor = 'slurm'
  }

  // HPC profile
  hpc {
    process.executor = 'slurm'
    params.resource_multiplier = 3
    params.parallel_multiplier = 5
  }

  // Singularity profile for local server
  singularity {
    singularity.enabled = true
    singularity.autoMounts = true
    singularity.runOptions = "--bind /mnt/sas:/mnt/sas"
    process.container = params.singularity_path
  }

  // Singularity profile for HPC cluster
  singularity_hpc {
    singularity.enabled = true
    singularity.autoMounts = false
    singularity.runOptions = "--bind /scratch"
    process.container = params.singularity_path
    params.resource_multiplier = 3
    params.parallel_multiplier = 5
  }
}

// ========================================
// Per-Process Resource Configuration
// ========================================
process {

  // Default resources for all processes
  cpus = { 2 * params.resource_multiplier }
  memory = { 4.GB * params.resource_multiplier * task.attempt }
  time = '167h'
  maxForks = { params.max_parallel_samples * params.parallel_multiplier }
  maxRetries = 2
  errorStrategy = { task.exitStatus in [137,140] ? 'retry' : 'finish' }

  // =====================================
  // High CPU and memory processes
  // =====================================

  withName: 'BUILD_STAR_INDEX' {
    cpus = { 20 * params.resource_multiplier }
    memory = { 20.GB * params.resource_multiplier * task.attempt }
    time = '167h'
    cache = 'lenient'
  }

  withName: 'STAR_ALIGN' {
    cpus = { 20 * params.resource_multiplier }
    time = '167h'
    memory = { 36.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // BLAST processes (parallel execution)
  // =====================================

  withName: 'BLAST_MAPPED_READS_MULTI' {
    cpus = { 40 * params.resource_multiplier }
    time = '167h'
    memory = { 40.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'BLAST_UNMAPPED_READS_MULTI' {
    cpus = { 40 * params.resource_multiplier }
    time = '167h'
    memory = { 40.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // DecontaMiner processes
  // =====================================

  withName: 'DECONTAMINER_STEP1_STAR_MAPPED' {
    cpus = { 20 * params.resource_multiplier }
    time = '167h'
    memory = { 20.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'DECONTAMINER_STEP1_STAR_UNMAPPED' {
    cpus = { 20 * params.resource_multiplier }
    time = '167h'
    memory = { 20.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'DECONTAMINER_STEP2' {
    cpus = { 20 * params.resource_multiplier }
    time = '167h'
    memory = { 20.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'DECONTAMINER_STEP3' {
    cpus = { 4 * params.resource_multiplier }
    time = '167h'
    memory = { 8.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // QC tools (medium resources)
  // =====================================

  withName: 'QUALIMAP_BAMQC' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'QUALIMAP_RNASEQ' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'DEEPTOOLS_GC' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'PICARD_GC_BIAS' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'BEDTOOLS_GC_COVERAGE' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'MAPINSIGHTS' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // FastQ processing
  // =====================================

  withName: 'FASTQ_SCREEN' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'FASTQC_INPUT_FASTQ' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'FASTQC_MAPPED_BAM' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'FASTQC_UNMAPPED_FASTQ' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // Subsetting processes (light)
  // =====================================

  withName: 'SUBSET_FASTQ_FOR_QC' {
    cpus = { 1 * params.resource_multiplier }
    time = '167h'
    memory = { 6.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'SUBSET_FASTQ_FOR_STAR' {
    cpus = { 1 * params.resource_multiplier }
    time = '167h'
    memory = { 6.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'SUBSET_BAM_FOR_QC' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'SUBSET_UNMAPPED_FOR_BLAST' {
    cpus = { 1 * params.resource_multiplier }
    time = '167h'
    memory = { 6.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'SUBSET_UNMAPPED_FOR_DECONTAMINER' {
    cpus = { 1 * params.resource_multiplier }
    time = '167h'
    memory = { 8.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // Indexing processes
  // =====================================

  withName: 'INDEX_INPUT_BAM' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 8.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // Reference preparation
  // =====================================

  withName: 'PREPARE_STRAIN_REFERENCE' {
    cpus = { 1 * params.resource_multiplier }
    time = '167h'
    memory = { 4.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'PREP_STRAIN_REFERENCE_FOR_QC' {
    cpus = { 15 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // Reporting processes (light)
  // =====================================

  withName: 'BLAST_PLOT_CHARTS' {
    cpus = { 2 * params.resource_multiplier }
    time = '167h'
    memory = { 4.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'CONTAMINATION_FINAL_REPORT_MULTI' {
    cpus = { 1 * params.resource_multiplier }
    time = '167h'
    memory = { 4.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'MULTIQC' {
    cpus = { 4 * params.resource_multiplier }
    time = '167h'
    memory = { 16.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  // =====================================
  // Utility processes (minimal)
  // =====================================

  withName: 'WRITE_PIPELINE_INFO' {
    cpus = { 1 * params.resource_multiplier }
    time = '167h'
    memory = { 2.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }

  withName: 'COPY_SAMPLE_SHEET' {
    cpus = { 1 * params.resource_multiplier }
    time = '167h'
    memory = { 1.GB * params.resource_multiplier * task.attempt }
    cache = 'lenient'
  }
}

if (params.outdir != null) {
  toReports = params.outdir + "/NextflowReports"

  timeline {
    enabled = true
    overwrite = true
    file = "${toReports}/timeline.html"
  }
  report {
    enabled = true
    overwrite = true
    file = "${toReports}/report.html"
  }
  trace {
    enabled = true
    overwrite = true
    file = "${toReports}/trace.txt"
  }
  dag {
    enabled = true
    overwrite = true
    file = "${toReports}/dag.html"
  }
}