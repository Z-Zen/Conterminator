Bootstrap: docker
From: ubuntu:22.04

%labels
    Author Alaa Badreddine
    Version 1.2
    Description Conterminator pipeline tools container

%files
    # Copy modified DecontaMiner scripts from host to container
    /mnt/sas/Tools/decontaminer-RNAseq /opt/tools/decontaminer
    # Copy container-specific config file
    /mnt/sas/Tools/decontaminer-RNAseq/decontaMiner_1.4/config_files/configure_container.txt /opt/tools/decontaminer/decontaMiner_1.4/config_files/configure_container.txt
    # Copy FastQ Screen genomes INTO the container
    /mnt/sas/Tools/FastQ-Screen-0.16.0/FastQ_Screen_Genomes /opt/fastq_screen_genomes

%help
    Conterminator v1.2 - RNA-seq QC and Contamination Detection Pipeline

    This container includes all required bioinformatics tools:
    - STAR aligner (2.7.11b)
    - samtools (1.22.1), seqtk, bedtools (2.31.1)
    - FastQC (0.12.1), FastQ Screen (0.16.0), MultiQC
    - Picard (3.4.0), Qualimap (2.3), MapInsights
    - BLAST+ suite (2.17.0+)
    - DeepTools (3.5.6), BBMap (39.37)
    - Bowtie2 (2.5.4)
    - DecontaMiner (1.4, modified for pipeline)
    - Python3 with plotting libraries
    - FastQ Screen reference genomes (included)
    
    Usage with Nextflow:
        nextflow run main.nf -profile singularity_hpc,slurm
    
    FastQ Screen genomes are pre-installed at:
        /opt/fastq_screen_genomes/

%environment
    # Set tool paths
    export PATH=/opt/tools/bin:$PATH
    export PATH=/opt/tools/STAR/bin:$PATH
    export PATH=/opt/tools/FastQC:$PATH
    export PATH=/opt/tools/bbmap:$PATH
    export PATH=/opt/tools/seqtk:$PATH
    export PATH=/opt/tools/blast/bin:$PATH
    export PATH=/opt/tools/decontaminer:$PATH
    export PATH=/opt/tools/bowtie2:$PATH
    export PYTHONPATH=/opt/python_libs:$PYTHONPATH

    # Locale settings to prevent Perl warnings
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8
    export LANGUAGE=en_US.UTF-8

    # BLAST database path (will be bind-mounted)
    export BLASTDB=/blastdb

    # FastQ Screen configuration
    export FASTQ_SCREEN_CONF=/opt/tools/fastq_screen.conf

    # Java memory for tools
    export _JAVA_OPTIONS="-Xmx10g"

%post
    # =====================
    # Configure non-interactive installation
    # =====================
    export DEBIAN_FRONTEND=noninteractive
    export TZ=Europe/Zurich
    
    # Pre-configure tzdata
    ln -snf /usr/share/zoneinfo/$TZ /etc/localtime
    echo $TZ > /etc/timezone
    
    # Update and install basic dependencies
    apt-get update && apt-get install -y \
        wget \
        curl \
        git \
        build-essential \
        libz-dev \
        libbz2-dev \
        liblzma-dev \
        libcurl4-openssl-dev \
        libssl-dev \
        libncurses5-dev \
        unzip \
        python3 \
        python3-pip \
        python3-dev \
        gawk \
        bc \
        perl \
        cpanminus \
        fontconfig \
        libfontconfig1-dev \
        libfreetype6-dev \
        libpng-dev \
        libtiff5-dev \
        libjpeg-dev \
        libxml2-dev \
        libcairo2-dev \
        libgd-dev \
        libgd-perl \
        locales \
        software-properties-common \
        dirmngr \
        gnupg \
        apt-transport-https \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    # Configure locale to prevent Perl warnings
    echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
    locale-gen en_US.UTF-8
    update-locale LANG=en_US.UTF-8

    # =====================
    # Install Java 17 (required for Picard 3.4.0)
    # =====================
    echo "Installing Java 17..."
    apt-get update
    apt-get install -y openjdk-17-jdk openjdk-17-jre
    # Set Java 17 as default
    update-alternatives --set java /usr/lib/jvm/java-17-openjdk-amd64/bin/java
    update-alternatives --set javac /usr/lib/jvm/java-17-openjdk-amd64/bin/javac
    java -version
    rm -rf /var/lib/apt/lists/*
    
    # =====================
    # Install R 4.5.2 from CRAN
    # =====================
    echo "Installing R 4.5.2 from CRAN..."
    
    # Add CRAN repository key
    wget -qO- https://cloud.r-project.org/bin/linux/ubuntu/marutter_pubkey.asc | tee -a /etc/apt/trusted.gpg.d/cran_ubuntu_key.asc
    
    # Add CRAN repository
    echo "deb https://cloud.r-project.org/bin/linux/ubuntu jammy-cran40/" | tee -a /etc/apt/sources.list.d/cran-r.list
    
    # Update and install R
    apt-get update
    apt-get install -y --no-install-recommends r-base r-base-dev
    
    # Verify R version
    R --version
    
    # Create tools directory
    mkdir -p /opt/tools/bin
    cd /opt/tools
    
    # =====================
    # Install samtools (1.22.1)
    # =====================
    echo "Installing samtools..."
    wget https://github.com/samtools/samtools/releases/download/1.22.1/samtools-1.22.1.tar.bz2
    tar -xjf samtools-1.22.1.tar.bz2
    cd samtools-1.22.1
    ./configure --prefix=/opt/tools
    make -j
    make install
    cd ..
    rm -rf samtools-1.22.1*
    
    # =====================
    # Install STAR (2.7.11b)
    # =====================
    echo "Installing STAR..."
    cd /opt/tools
    wget https://github.com/alexdobin/STAR/archive/2.7.11b.tar.gz
    tar -xzf 2.7.11b.tar.gz
    mkdir -p STAR/bin
    cp STAR-2.7.11b/bin/Linux_x86_64_static/STAR STAR/bin/
    chmod +x STAR/bin/STAR
    rm -rf STAR-2.7.11b 2.7.11b.tar.gz
    
    # =====================
    # Install seqtk
    # =====================
    echo "Installing seqtk..."
    git clone https://github.com/lh3/seqtk.git
    cd seqtk
    make -j
    cp seqtk /opt/tools/bin/
    cd ..
    rm -rf seqtk
    
    # =====================
    # Install BEDTools (2.31.1)
    # =====================
    echo "Installing BEDTools..."
    wget https://github.com/arq5x/bedtools2/releases/download/v2.31.1/bedtools-2.31.1.tar.gz
    tar -xzf bedtools-2.31.1.tar.gz
    cd bedtools2
    make -j
    cp bin/* /opt/tools/bin/
    cd ..
    rm -rf bedtools2 bedtools-2.31.1.tar.gz
    
    # =====================
    # Install Bowtie2 (2.5.4) - Required for FastQ Screen
    # =====================
    echo "Installing Bowtie2..."
    cd /opt/tools
    wget https://github.com/BenLangmead/bowtie2/releases/download/v2.5.4/bowtie2-2.5.4-linux-x86_64.zip
    unzip bowtie2-2.5.4-linux-x86_64.zip
    mv bowtie2-2.5.4-linux-x86_64 bowtie2
    # Add to PATH
    ln -s /opt/tools/bowtie2/bowtie2* /opt/tools/bin/
    rm bowtie2-2.5.4-linux-x86_64.zip
    
    # =====================
    # Install FastQC (0.12.1)
    # =====================
    echo "Installing FastQC..."
    cd /opt/tools
    wget https://www.bioinformatics.babraham.ac.uk/projects/fastqc/fastqc_v0.12.1.zip
    unzip fastqc_v0.12.1.zip
    # FastQC is already in /opt/tools/FastQC after unzip, no need to move
    chmod +x /opt/tools/FastQC/fastqc
    ln -s /opt/tools/FastQC/fastqc /opt/tools/bin/fastqc
    rm fastqc_v0.12.1.zip

    # =====================
    # Install FastQ Screen (0.16.0)
    # =====================
    echo "Installing FastQ Screen..."
    cd /opt/tools
    wget https://github.com/StevenWingett/FastQ-Screen/archive/refs/tags/v0.16.0.tar.gz -O fastq_screen_v0.16.0.tar.gz
    tar -xzf fastq_screen_v0.16.0.tar.gz
    # Rename to FastQ_Screen for consistency
    mv FastQ-Screen-0.16.0 FastQ_Screen
    chmod +x /opt/tools/FastQ_Screen/fastq_screen

    # Install required Perl modules for FastQ Screen
    echo "Installing Perl modules for FastQ Screen..."
    cpanm --notest GD::Graph::bars || true
    cpanm --notest GD::Graph::lines || true
    cpanm --notest GD::Graph::linespoints || true

    # Create wrapper script instead of symlink (Perl script needs proper interpreter)
    cat > /opt/tools/bin/fastq_screen << 'EOF'
#!/bin/bash
perl /opt/tools/FastQ_Screen/fastq_screen "$@"
EOF
    chmod +x /opt/tools/bin/fastq_screen
    rm fastq_screen_v0.16.0.tar.gz

    # =====================
    # Create FastQ Screen Configuration File
    # =====================
    echo "Creating FastQ Screen configuration..."
    cat > /opt/tools/fastq_screen.conf << 'FQSCONF'
# FastQ Screen Configuration for Conterminator Container
# All paths point to genomes embedded in the container

BOWTIE2 /opt/tools/bowtie2/bowtie2
THREADS 15

DATABASE Human      /opt/fastq_screen_genomes/Human/Homo_sapiens.GRCh38
DATABASE Mouse      /opt/fastq_screen_genomes/Mouse/Mus_musculus.GRCm38
DATABASE Rat        /opt/fastq_screen_genomes/Rat/Rnor_6.0
DATABASE Drosophila /opt/fastq_screen_genomes/Drosophila/BDGP6
DATABASE Worm       /opt/fastq_screen_genomes/Worm/Caenorhabditis_elegans.WBcel235
DATABASE Yeast      /opt/fastq_screen_genomes/Yeast/Saccharomyces_cerevisiae.R64-1-1
DATABASE Arabidopsis /opt/fastq_screen_genomes/Arabidopsis/Arabidopsis_thaliana.TAIR10
DATABASE Ecoli      /opt/fastq_screen_genomes/E_coli/Ecoli
DATABASE rRNA       /opt/fastq_screen_genomes/rRNA/GRCm38_rRNA
DATABASE MT         /opt/fastq_screen_genomes/Mitochondria/mitochondria
DATABASE PhiX       /opt/fastq_screen_genomes/PhiX/phi_plus_SNPs
DATABASE Lambda     /opt/fastq_screen_genomes/Lambda/Lambda
DATABASE Vectors    /opt/fastq_screen_genomes/Vectors/Vectors
DATABASE Adapters   /opt/fastq_screen_genomes/Adapters/Contaminants
FQSCONF

    echo "FastQ Screen configuration created at /opt/tools/fastq_screen.conf"

    # =====================
    # Install Picard (3.4.0)
    # =====================
    echo "Installing Picard..."
    cd /opt/tools
    mkdir -p picard
    wget https://github.com/broadinstitute/picard/releases/download/3.4.0/picard.jar -O picard/picard.jar
    
    # =====================
    # Install BLAST+ (2.17.0)
    # =====================
    echo "Installing BLAST+..."
    cd /opt/tools
    wget https://ftp.ncbi.nlm.nih.gov/blast/executables/blast+/2.17.0/ncbi-blast-2.17.0+-x64-linux.tar.gz
    tar -xzf ncbi-blast-2.17.0+-x64-linux.tar.gz
    mv ncbi-blast-2.17.0+ blast
    rm ncbi-blast-2.17.0+-x64-linux.tar.gz
    
    # =====================
    # Install BBMap (39.37)
    # =====================
    echo "Installing BBMap..."
    cd /opt/tools
    wget https://sourceforge.net/projects/bbmap/files/BBMap_39.37.tar.gz
    tar -xzf BBMap_39.37.tar.gz
    # bbmap directory is created by tar, already in /opt/tools/bbmap
    chmod +x /opt/tools/bbmap/*.sh
    rm BBMap_39.37.tar.gz
    
    # =====================
    # Install UCSC tools (faCount, faToTwoBit)
    # =====================
    echo "Installing UCSC tools..."
    wget http://hgdownload.cse.ucsc.edu/admin/exe/linux.x86_64/faCount -O /opt/tools/bin/faCount
    wget http://hgdownload.cse.ucsc.edu/admin/exe/linux.x86_64/faToTwoBit -O /opt/tools/bin/faToTwoBit
    chmod +x /opt/tools/bin/faCount /opt/tools/bin/faToTwoBit
    
    # =====================
    # Install Python packages
    # =====================
    echo "Installing Python packages..."
    pip3 install --no-cache-dir \
        numpy \
        pandas \
        matplotlib \
        seaborn \
        plotly \
        biopython \
        pysam \
        multiqc \
        deeptools
    
    # =====================
    # Install R and required packages
    # =====================
    echo "Installing R packages..."
    R -e "install.packages(c('ggplot2', 'dplyr', 'tidyr', 'reshape2', 'RColorBrewer', 'gridExtra'), repos='https://cloud.r-project.org/')"
    
    # =====================
    # Install Qualimap (2.3)
    # =====================
    echo "Installing Qualimap..."
    cd /opt/tools
    wget https://bitbucket.org/kokonech/qualimap/downloads/qualimap_v2.3.zip
    unzip qualimap_v2.3.zip
    # Rename to qualimap for consistency
    mv qualimap_v2.3 qualimap
    chmod +x /opt/tools/qualimap/qualimap

    # Fix Qualimap wrapper for Java 17 compatibility
    # Remove obsolete -XX:MaxPermSize option (removed in Java 8+)
    sed -i 's/-XX:MaxPermSize=[0-9]*[mMgG]//g' /opt/tools/qualimap/qualimap

    ln -s /opt/tools/qualimap/qualimap /opt/tools/bin/qualimap
    rm qualimap_v2.3.zip
    
    # =====================
    # Configure DecontaMiner
    # =====================
    echo "Setting up DecontaMiner..."
    # Set execute permissions on DecontaMiner scripts
    if [ -d "/opt/tools/decontaminer" ]; then
        find /opt/tools/decontaminer -type f \( -name "*.pl" -o -name "*.sh" \) -exec chmod +x {} \; 2>/dev/null || true
        echo "DecontaMiner configured at /opt/tools/decontaminer"
    else
        echo "WARNING: DecontaMiner directory not found. Ensure it was copied in %files section."
    fi

    # =====================
    # Build MapInsights from source
    # =====================
    echo "Building MapInsights from source..."
    cd /opt/tools
    git clone https://github.com/subrata-codeons/mapinsights
    cd mapinsights
    make
    if [ -f "mapinsights" ]; then
        chmod +x mapinsights
        ln -s /opt/tools/mapinsights/mapinsights /opt/tools/bin/mapinsights
        echo "MapInsights successfully compiled and installed"
    else
        echo "WARNING: MapInsights compilation failed"
    fi
    cd /opt/tools

    # =====================
    # Install libgtextutils (dependency for FASTX-Toolkit)
    # =====================
    echo "Installing libgtextutils (FASTX dependency)..."
    cd /opt/tools
    wget https://github.com/agordon/libgtextutils/releases/download/0.7/libgtextutils-0.7.tar.gz
    tar -xzf libgtextutils-0.7.tar.gz
    cd libgtextutils-0.7
    # Patch for modern C++ compiler compatibility
    sed -i 's/return input_stream ;/return static_cast<bool>(input_stream);/' src/gtextutils/text_line_reader.cpp
    ./configure --prefix=/usr/local
    make && make install
    cd /opt/tools
    rm -rf libgtextutils-0.7.tar.gz libgtextutils-0.7
    echo "libgtextutils installed"

    # =====================
    # Install FASTX-Toolkit
    # =====================
    echo "Installing FASTX-Toolkit..."
    cd /opt/tools
    wget https://github.com/agordon/fastx_toolkit/releases/download/0.0.14/fastx_toolkit-0.0.14.tar.bz2
    tar -xjf fastx_toolkit-0.0.14.tar.bz2
    cd fastx_toolkit-0.0.14
    # Patch for implicit-fallthrough warnings in modern gcc
    find . -name "*.cpp" -exec sed -i '/usage();$/a\                        break;' {} \;
    export PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:$PKG_CONFIG_PATH
    export LD_LIBRARY_PATH=/usr/local/lib:$LD_LIBRARY_PATH
    ./configure --prefix=/usr/local
    make && make install
    cd /opt/tools
    rm -rf fastx_toolkit-0.0.14.tar.bz2 fastx_toolkit-0.0.14
    echo "FASTX-Toolkit installed"

    # =====================
    # Install SortMeRNA v4.3.6 (self-extracting installer)
    # =====================
    echo "Installing SortMeRNA v4.3.6..."
    cd /opt/tools
    mkdir -p /opt/tools/sortmerna
    wget https://github.com/biocore/sortmerna/releases/download/v4.3.6/sortmerna-4.3.6-Linux.sh
    bash sortmerna-4.3.6-Linux.sh --skip-license --prefix=/opt/tools/sortmerna
    ln -s /opt/tools/sortmerna/bin/sortmerna /opt/tools/bin/sortmerna
    rm -f sortmerna-4.3.6-Linux.sh
    echo "SortMeRNA v4.3.6 installed"

    # =====================
    # Create wrapper scripts
    # =====================
    
    # Picard wrapper
    cat > /opt/tools/bin/picard << 'EOF'
#!/bin/bash
java -jar /opt/tools/picard/picard.jar "$@"
EOF
    chmod +x /opt/tools/bin/picard
    
    # =====================
    # Verify FastQ Screen Genomes
    # =====================
    echo "Verifying FastQ Screen genomes..."
    if [ -d "/opt/fastq_screen_genomes" ]; then
        echo "FastQ Screen genomes found at /opt/fastq_screen_genomes"
        ls -la /opt/fastq_screen_genomes/
    else
        echo "WARNING: FastQ Screen genomes directory not found!"
    fi
    
    # =====================
    # Cleanup
    # =====================
    apt-get clean
    rm -rf /var/lib/apt/lists/*
    
    echo "Container build complete!"

%runscript
    echo "========================================="
    echo "Conterminator v1.2 Container"
    echo "========================================="
    echo ""
    echo "Installed Tools and Versions:"
    echo "----------------------------"
    echo "STAR:           $(STAR --version 2>&1 | head -1)"
    echo "Samtools:       $(samtools --version 2>&1 | grep -m1 '^samtools' | awk '{print $2}')"
    echo "FastQC:         $(fastqc --version 2>&1 | grep Fast)"
    echo "FastQ Screen:   $(fastq_screen --version 2>&1 | grep Fast | grep -oP 'v\K[\d\.]+' || echo '0.16.0')"
    echo "Bowtie2:        $(bowtie2 --version 2>&1 | head -1 | awk '{print $3}')"
    echo "Qualimap:       $(qualimap bamqc --version 2>&1 | grep -oP 'QualiMap v\.\K[\d\.]+')"
    echo "Picard:         $(java -jar /opt/tools/picard/picard.jar CollectGcBiasMetrics --version 2>&1 | grep -v '^Picked up' | grep -oP 'Version:\s*\K[\d\.]+')"
    echo "DeepTools:      $(deeptools --version 2>&1 | awk '{print $2}')"
    echo "BEDTools:       $(bedtools --version 2>&1 | awk '{print $2}')"
    echo "BLAST+:         $(blastn -version 2>&1 | head -1 | awk '{print $2}')"
    echo "DecontaMiner:   1.4 (custom modified)"
    echo "Seqtk:          $(seqtk 2>&1 | grep -oP 'Version: \K[\S]+')"
    echo "BBMap:          $(reformat.sh --version 2>&1 | grep -oP 'BBTools version \K[\d\.]+')"
    echo "MultiQC:        $(multiqc --version 2>&1 | awk '{print $3}')"
    echo ""
    echo "Python:         $(python3 --version 2>&1 | awk '{print $2}')"
    echo "R:              $(R --version 2>&1 | grep 'R version' | awk '{print $3}')"
    echo ""
    echo "FastQ Screen:   Genomes embedded at /opt/fastq_screen_genomes"
    echo "========================================="
    echo "Usage: singularity exec conterminator.sif <tool> --help"
    echo "========================================="

%test
    # Test that key tools are installed and working
    echo "========================================="
    echo "Testing Conterminator Tool Installations"
    echo "========================================="
    echo ""

    FAILED=0

    # Test STAR (2.7.11b)
    echo -n "Testing STAR... "
    VERSION=$(STAR --version 2>&1 | head -1)
    if [ -n "$VERSION" ]; then
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test Bowtie2 (2.5.4)
    echo -n "Testing Bowtie2... "
    VERSION=$(bowtie2 --version 2>&1 | head -1 | awk '{print $3}')
    if [ -n "$VERSION" ]; then
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test Samtools (1.22.1)
    echo -n "Testing Samtools... "
    VERSION=$(samtools --version 2>&1 | grep -m1 '^samtools' | awk '{print $2}')
    if [ -n "$VERSION" ]; then
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test FastQC (0.12.1)
    echo -n "Testing FastQC... "
    VERSION=$(fastqc --version 2>&1 | grep Fast)
    if [ -n "$VERSION" ]; then
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test FastQ Screen (0.16.0)
    echo -n "Testing FastQ Screen... "
    VERSION=$(fastq_screen --version 2>&1 | grep Fast | grep -oP 'v\K[\d\.]+')
    if [ -n "$VERSION" ]; then
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test FastQ Screen Config
    echo -n "Testing FastQ Screen Config... "
    if [ -f "/opt/tools/fastq_screen.conf" ]; then
        echo "OK - Config file exists"
    else
        echo "FAILED - Config file missing"
        FAILED=$((FAILED+1))
    fi

    # Test FastQ Screen Genomes
    echo -n "Testing FastQ Screen Genomes... "
    if [ -d "/opt/fastq_screen_genomes" ]; then
        echo "OK - Genomes directory exists"
    else
        echo "FAILED - Genomes directory missing"
        FAILED=$((FAILED+1))
    fi

    # Test Qualimap (2.3)
    echo -n "Testing Qualimap... "
    if qualimap bamqc --version 2>&1 | grep -q "QualiMap"; then
        VERSION=$(qualimap bamqc --version 2>&1 | grep -oP 'QualiMap v\.\K[\d\.]+')
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test Picard (3.4.0)
    echo -n "Testing Picard... "
    if [ -f "/opt/tools/picard/picard.jar" ]; then
        VERSION=$(java -jar /opt/tools/picard/picard.jar CollectGcBiasMetrics --version 2>&1 | grep -v '^Picked up' | grep -oP 'Version:\s*\K[\d\.]+')
        if [ -n "$VERSION" ]; then
            echo "OK - $VERSION"
        else
            echo "FAILED"
            FAILED=$((FAILED+1))
        fi
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test DeepTools (3.5.6)
    echo -n "Testing DeepTools... "
    if deeptools --version >/dev/null 2>&1; then
        VERSION=$(deeptools --version 2>&1 | awk '{print $2}')
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test BEDTools (2.31.1)
    echo -n "Testing BEDTools... "
    if bedtools --version >/dev/null 2>&1; then
        VERSION=$(bedtools --version 2>&1 | awk '{print $2}')
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test BLAST+ (2.17.0+)
    echo -n "Testing BLAST+... "
    if blastn -version >/dev/null 2>&1; then
        VERSION=$(blastn -version 2>&1 | head -1 | awk '{print $2}')
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test DecontaMiner (1.4)
    echo -n "Testing DecontaMiner... "
    if [ -d "/opt/tools/decontaminer" ]; then
        echo "OK - 1.4 (custom modified)"
    else
        echo "FAILED - Directory not found"
        FAILED=$((FAILED+1))
    fi

    # Test Seqtk
    echo -n "Testing Seqtk... "
    if seqtk 2>&1 | grep -q "Version:"; then
        VERSION=$(seqtk 2>&1 | grep -oP 'Version: \K[\S]+')
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test BBMap (39.37)
    echo -n "Testing BBMap... "
    BBMAP_OUTPUT=$(reformat.sh --version 2>&1)
    if echo "$BBMAP_OUTPUT" | grep -q 'BBTools version'; then
        VERSION=$(echo "$BBMAP_OUTPUT" | grep -oP 'BBTools version \K[\d\.]+')
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test MultiQC
    echo -n "Testing MultiQC... "
    if multiqc --version >/dev/null 2>&1; then
        VERSION=$(multiqc --version 2>&1 | awk '{print $3}')
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test Python3
    echo -n "Testing Python3... "
    VERSION=$(python3 --version 2>&1 | awk '{print $2}')
    if [ -n "$VERSION" ]; then
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    # Test R
    echo -n "Testing R... "
    R_OUTPUT=$(R --version)
    if echo "$R_OUTPUT" | grep -q 'R version';
        then
        VERSION=$(echo -e "$R_OUTPUT" | grep -oP 'R version \K[\d\.]+')
        echo "OK - $VERSION"
    else
        echo "FAILED"
        FAILED=$((FAILED+1))
    fi

    echo ""
    echo "========================================="
    if [ $FAILED -eq 0 ]; then
        echo "✓ All tests passed!"
        echo "========================================="
        exit 0
    else
        echo "✗ $FAILED test(s) failed!"
        echo "========================================="
        exit 1
    fi
